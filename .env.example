# Traffic Pulse — Environment Configuration
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your actual .env file to git.
# ─────────────────────────────────────────────────────────────────────


# ── Database (REQUIRED) ──────────────────────────────────────────────
# PostgreSQL connection URL — asyncpg driver.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
#
# Local development (Docker):
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/traffic_pulse
#
# Production (example):
# DATABASE_URL=postgresql+asyncpg://tp_user:strongpassword@db.yourhost.com:5432/traffic_pulse


# ── ML Models ────────────────────────────────────────────────────────
# Path to directory that contains the trained .joblib model files.
MODEL_DIR=Model


# ── Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR


# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ── SMTP Email Alerts (optional) ─────────────────────────────────────
# Leave SMTP_HOST blank to disable email alerts entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_RECIPIENTS=


# ── Alert Thresholds ─────────────────────────────────────────────────
HIGH_IMPACT_CLEARANCE_THRESHOLD_MIN=360
CLOSURE_PROB_ALERT_THRESHOLD=0.7


# ── Retraining Schedule ──────────────────────────────────────────────
# Cron expression for automatic model retraining. Leave blank to disable.
# Example: "0 2 * * 0"  → every Sunday at 2 AM
RETRAIN_SCHEDULE=
