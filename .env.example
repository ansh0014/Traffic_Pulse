# GridLock 2.0 — Environment Configuration
# Copy this file to .env and fill in your values

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./gridlock.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gridlock

# ML Model directory (relative to project root)
MODEL_DIR=Model

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP Email Alerts (optional — leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_RECIPIENTS=

# Alert Thresholds
HIGH_IMPACT_CLEARANCE_THRESHOLD_MIN=360
CLOSURE_PROB_ALERT_THRESHOLD=0.7

# Retraining (cron expression, empty to disable)
RETRAIN_SCHEDULE=
